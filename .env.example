# ===== תבנית משתני סביבה =====
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# אין לשמור את .env ב-git (הוא מופיע ב-.gitignore).

# מפתח ה-API של Anthropic עבור Claude
# ניתן להפיק כאן: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# מפתח ה-API של OpenAI עבור יצירת תמונות (יובל / סקיל gpt-image-gen)
# ניתן להפיק כאן: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- משתנים עתידיים (לפי הצורך) ---
# מפתחות לשירותים חיצוניים שהצוות עשוי להשתמש בהם בהמשך,
# למשל מחקר (חן) או יצירת תמונות (יובל):
# RESEARCH_API_KEY=
# IMAGE_API_KEY=
